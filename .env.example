# ─── FlySwarm Environment Variables (template) ───────────
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.

# Local backend server
PORT=3000
# Landing page storage adapter: json | sqlite
STORAGE_BACKEND=json
# Optional storage file overrides:
# FLYSWARM_EMAILS_FILE=apps/demo-landing/emails.json
# FLYSWARM_SQLITE_FILE=apps/demo-landing/data/signups.sqlite3

# ─── Model Providers (SECRETS ONLY) ──────────────────────
# The system is model-agnostic: local (Ollama) or any cloud provider.
# Provider/model SELECTION & routing live in `config/models.yaml` (committed, no secrets).
# Only API keys / base URLs belong here. Keys use the LiteLLM naming convention.
# `LLM_PROVIDER` overrides `default_provider` from config/models.yaml.

# Quick switch (optional): openai | anthropic | google | ollama
# LLM_PROVIDER=ollama

# Local model (Ollama) — no key needed, just the endpoint
# OLLAMA_BASE_URL=http://localhost:11434

# Cloud providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Google Gemini — LiteLLM reads GEMINI_API_KEY for `gemini/*` models;
# GOOGLE_API_KEY is accepted as an alias.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ─── Reserved for FUTURE swarm phases (not used in the landing-page session) ───
# TELEGRAM_BOT_TOKEN=
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
# TRAVELPAYOUTS_TOKEN=
# DATABASE_URL=
