# ─── FlySwarm Environment Variables (template) ───────────
# Copy this file to `.env` and fill in real values.
# `.env` is git-ignored and must NEVER be committed.

# Local backend server
PORT=3000
# Landing page storage adapter: json | sqlite
STORAGE_BACKEND=json
# Optional storage file overrides:
# FLYSWARM_EMAILS_FILE=apps/demo-landing/emails.json
# FLYSWARM_SQLITE_FILE=apps/demo-landing/data/signups.sqlite3

# ─── Model Providers (SECRETS ONLY) ──────────────────────
# The system is model-agnostic: local (Ollama) or any cloud provider.
# Provider/model SELECTION & routing live in `config/models.yaml` (committed, no secrets).
# Only API keys / base URLs belong here. Keys use the LiteLLM naming convention.
# `LLM_PROVIDER` overrides `default_provider` from config/models.yaml.

# Quick switch (optional): openai | anthropic | google | ollama
# LLM_PROVIDER=ollama

# Local model (Ollama) — no key needed, just the endpoint
# OLLAMA_BASE_URL=http://localhost:11434

# Cloud providers
# OPENAI_API_KEY=
# ANTHROPIC_API_KEY=
# Google Gemini — LiteLLM reads GEMINI_API_KEY for `gemini/*` models;
# GOOGLE_API_KEY is accepted as an alias.
# GEMINI_API_KEY=
# GOOGLE_API_KEY=

# ─── Flight Sources (SECRETS ONLY) ───────────────────────
# Source SELECTION & routing live in `config/sources.yaml` (committed, no secrets).
# Only tokens / affiliate markers belong here. `FLIGHT_SOURCE` overrides
# `default_source` from config/sources.yaml.

# Travelpayouts (Aviasales) Data Access API — affiliate network token + marker.
# Get a token: https://www.travelpayouts.com/developers/api
# TRAVELPAYOUTS_API_KEY=
# Affiliate marker used to build monetized booking links (Notification Agent).
# TRAVELPAYOUTS_MARKER=

# ─── Swarm storage (SECRETS ONLY) ────────────────────────
# Backend SELECTION & tunables live in `config/storage.yaml` (committed, no
# secrets). Default is local SQLite (no server, no cost). Swapping to Postgres
# later is a config + DATABASE_URL change only — no logic changes.
# `SWARM_STORAGE_BACKEND` overrides `default_backend` (sqlite | postgres).
# Distinct from the demo-landing `STORAGE_BACKEND` above (json | sqlite).

# SWARM_STORAGE_BACKEND=sqlite
# Postgres connection string (only when SWARM_STORAGE_BACKEND=postgres):
# DATABASE_URL=

# ─── Telegram delivery (SECRETS ONLY) ────────────────────
# Bot token from @BotFather. Required to run the Telegram bot / scheduler.
# TELEGRAM_BOT_TOKEN=
# How often the scheduler scans + notifies (seconds; default 21600 = 6h).
# SCAN_INTERVAL_SECONDS=21600

# ─── Reserved for FUTURE swarm phases ────────────────────
# AMADEUS_API_KEY=
# AMADEUS_API_SECRET=
